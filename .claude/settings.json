{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "팀 공유 권한. 개인 권한은 settings.local.json (gitignore). 본 프로젝트는 npm/lint/test 도구가 없어 그쪽 명령은 allow에 추가하지 않음.",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push origin)",
      "Bash(git push origin main)",
      "Bash(git push origin HEAD)",
      "Bash(git tag:*)",
      "Bash(gh run:*)",
      "Bash(gh release:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh api:*)",
      "Bash(gh auth status)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(curl -sL https://raw.githubusercontent.com/*)",
      "Bash(curl -sI https://*)",
      "Bash(./gradlew assembleDebug)",
      "Bash(./gradlew assembleDebug:*)",
      "Bash(gradle assembleDebug:*)",
      "Bash(gradle tasks)",
      "Bash(python -m http.server:*)",
      "Bash(python3 -m http.server:*)",
      "Read(**)",
      "Edit(**)",
      "Write(./docs/**)",
      "Write(./.claude/**)",
      "Write(./CLAUDE.md)",
      "Write(./CHANGELOG.md)",
      "Write(./HANDOFF.md)",
      "Write(./README.md)",
      "Write(./.github/**)",
      "Write(./.gitignore)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf .git/*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.keystore)",
      "Read(./**/*.jks)",
      "Read(./**/.npmrc)",
      "Read(./**/credentials.json)",
      "Read(./**/service-account*.json)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Write(./**/*.keystore)",
      "Write(./**/*.jks)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout -- :*)",
      "Bash(gh release delete:*)",
      "Bash(gh release create:*)",
      "Bash(gh repo delete:*)",
      "Bash(npm publish:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rm:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"Add-Content -Path .claude/session.log -Value ('{0:yyyy-MM-dd HH:mm:ss} session-stop' -f (Get-Date))\""
          }
        ]
      }
    ]
  }
}
