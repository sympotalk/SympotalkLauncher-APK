{
  "name": "sympotalk-adb-deployer",
  "version": "0.2.1",
  "description": "Sympotalk ADB 병렬 배포 데스크탑 앱",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win portable nsis",
    "dist": "npm run build && electron-builder --win portable nsis",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "electron-store": "^7.0.3",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.sympotalk.adb-deployer",
    "productName": "Sympotalk ADB Deployer",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": ["out/**/*"],
    "extraResources": [
      { "from": "platform-tools", "to": "platform-tools" },
      { "from": "usb_driver",     "to": "usb_driver" }
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis",     "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ko_KR"],
      "language": "1042"
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.5.2",
    "vite": "^5.3.1",
    "zustand": "^4.5.4"
  }
}
