<?xml version="1.0" encoding="utf-8"?>
<!-- DPC 앱 매니페스트 — Device Owner 권한 + FGS + 부팅 수신 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 네트워크 / 다운로드 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 부팅 후 자동 시작 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground Service (다운로드·설치 중 백그라운드 생존) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- PackageInstaller 무음 설치 (Device Owner만 허용) -->
    <uses-permission android:name="android.permission.INSTALL_PACKAGES" />

    <!-- Launcher 프로세스 상태 폴링 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />

    <!-- Android 13+ 알림 (HealthWatchdog FGS 알림) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:testOnly="false">

        <!-- Device Admin / Device Owner 진입점 -->
        <receiver
            android:name=".DpcAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- 부팅 수신 → 상태 복원 후 업데이트 체크 재개 -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 업데이트·감시 작업을 수행하는 Foreground Service -->
        <service
            android:name=".DpcUpdateService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
